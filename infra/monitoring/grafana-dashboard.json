{
  "title": "Adaptive ML Inference",
  "uid": "adaptive-inference",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Frames Processed (total)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "adaptive_inference_frames_total",
          "legendFormat": "Frames"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2,
      "title": "Active WebSocket Connections",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "adaptive_inference_active_websocket_connections",
          "legendFormat": "Connections"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "thresholds": {
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 5 },
            { "color": "red", "value": 10 }
          ]
        }
      }
    },
    {
      "id": 3,
      "title": "Adaptive Path Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(adaptive_inference_adaptive_latency_seconds_bucket[1m])) * 1000",
          "legendFormat": "Adaptive p50 (ms)"
        },
        {
          "expr": "histogram_quantile(0.95, rate(adaptive_inference_adaptive_latency_seconds_bucket[1m])) * 1000",
          "legendFormat": "Adaptive p95 (ms)"
        },
        {
          "expr": "histogram_quantile(0.50, rate(adaptive_inference_baseline_latency_seconds_bucket[1m])) * 1000",
          "legendFormat": "Baseline p50 (ms)"
        },
        {
          "expr": "histogram_quantile(0.95, rate(adaptive_inference_baseline_latency_seconds_bucket[1m])) * 1000",
          "legendFormat": "Baseline p95 (ms)"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 4,
      "title": "Model Selection Distribution",
      "type": "piechart",
      "gridPos": { "x": 12, "y": 4, "w": 6, "h": 8 },
      "targets": [
        {
          "expr": "increase(adaptive_inference_model_selections_total[5m])",
          "legendFormat": "{{ model }}"
        }
      ],
      "options": { "pieType": "donut" }
    },
    {
      "id": 5,
      "title": "Frame Throughput (fps)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "rate(adaptive_inference_frames_total[30s])",
          "legendFormat": "Frames / sec"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "fps" }
      }
    },
    {
      "id": 6,
      "title": "Latency Savings (Baseline − Adaptive) p50",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "(histogram_quantile(0.50, rate(adaptive_inference_baseline_latency_seconds_bucket[1m])) - histogram_quantile(0.50, rate(adaptive_inference_adaptive_latency_seconds_bucket[1m]))) * 1000",
          "legendFormat": "Savings p50 (ms)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0 },
              { "color": "green", "value": 5 }
            ]
          }
        }
      }
    }
  ]
}
